# Windows system files
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS (in case files come from another machine)
.DS_Store
.AppleDouble
.LSOverride

# VS Code
.vscode/
*.code-workspace

# Node (if any tools get added later)
node_modules/
npm-debug.log*

# Build output (if a bundler is ever used)
dist/
build/

# Temporary / editor backup files
*.tmp
*.bak
*.swp
*~

# Large media originals (raw uncompressed files — keep optimized versions only)
*.psd
*.ai
*.indd
